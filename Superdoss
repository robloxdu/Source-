      if (loaded) {
        config = loaded;
        log('\n✓ ĐÃ TẢI CẤU HÌNH!', 'green');
      } else {
        log('\n✗ KHÔNG CÓ CẤU HÌNH!', 'red');
      }
      await question('\nNhấn Enter...');
    } else if (choice === '5') {
      deleteConfig();
      config = null;
      await question('\nNhấn Enter...');
    } else if (choice === '6') {
      log('\n👋 TẠM BIỆT!', 'yellow');
      rl.close();
      process.exit(0);
    }
  }
})();
